{% extends 'base.html.twig' %}
{% block title %}Réserver — {{ book.title }}{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4 shadow">
            <h2><i class="bi bi-calendar-check"></i> Réserver un livre</h2>
            <p class="text-muted">{{ book.title }}</p>
            <hr>
            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.startDate) }}
                    {{ form_widget(form.startDate, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.startDate) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.endDate) }}
                    {{ form_widget(form.endDate, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.endDate) }}
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Confirmer</button>
                    <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
