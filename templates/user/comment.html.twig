{% extends 'base.html.twig' %}
{% block title %}Commenter — {{ book.title }}{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4 shadow">
            <h2><i class="bi bi-chat-left-text"></i> Laisser un avis</h2>
            <p class="text-muted">{{ book.title }}</p>
            <hr>
            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.rating) }}
                    <div class="d-flex gap-3 mt-1">
                        {{ form_widget(form.rating) }}
                    </div>
                    {{ form_errors(form.rating) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.content) }}
                    {{ form_widget(form.content, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(form.content) }}
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Publier</button>
                    <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
