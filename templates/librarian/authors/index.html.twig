{% extends 'librarian/base_librarian.html.twig' %}
{% block title %}Auteurs{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-lines-fill"></i> Auteurs</h2>
    <a href="{{ path('app_librarian_author_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Ajouter</a>
</div>
<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark"><tr><th>Nom</th><th>Nb livres</th><th>Actions</th></tr></thead>
        <tbody>
        {% for author in authors %}
            <tr>
                <td>{{ author.fullName }}</td>
                <td>{{ author.books|length }}</td>
                <td>
                    <a href="{{ path('app_librarian_author_edit', {id: author.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="3" class="text-center text-muted">Aucun auteur.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
