{% extends 'librarian/base_librarian.html.twig' %}
{% block title %}Catégories{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-tags"></i> Catégories</h2>
    <a href="{{ path('app_librarian_category_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Ajouter</a>
</div>
<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark"><tr><th>Nom</th><th>Description</th><th>Nb livres</th><th>Actions</th></tr></thead>
        <tbody>
        {% for cat in categories %}
            <tr>
                <td>{{ cat.name }}</td>
                <td class="text-muted small">{{ cat.description|default('—') }}</td>
                <td>{{ cat.books|length }}</td>
                <td><a href="{{ path('app_librarian_category_edit', {id: cat.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a></td>
            </tr>
        {% else %}
            <tr><td colspan="4" class="text-center text-muted">Aucune catégorie.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
