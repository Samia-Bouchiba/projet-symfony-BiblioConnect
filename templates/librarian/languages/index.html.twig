{% extends 'librarian/base_librarian.html.twig' %}
{% block title %}Langues{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-translate"></i> Langues</h2>
    <a href="{{ path('app_librarian_language_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Ajouter</a>
</div>
<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark"><tr><th>Langue</th><th>Code</th><th>Nb livres</th></tr></thead>
        <tbody>
        {% for lang in languages %}
            <tr>
                <td>{{ lang.name }}</td>
                <td><span class="badge bg-secondary">{{ lang.code|default('—') }}</span></td>
                <td>{{ lang.books|length }}</td>
            </tr>
        {% else %}
            <tr><td colspan="3" class="text-center text-muted">Aucune langue.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
