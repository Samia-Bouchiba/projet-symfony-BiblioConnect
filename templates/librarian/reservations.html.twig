{% extends 'librarian/base_librarian.html.twig' %}
{% block title %}Réservations — Bibliothécaire{% endblock %}
{% block body %}
<h2 class="mb-4"><i class="bi bi-calendar-check"></i> Historique des réservations</h2>
<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr><th>Utilisateur</th><th>Livre</th><th>Du</th><th>Au</th><th>Demandé le</th><th>Statut</th></tr>
        </thead>
        <tbody>
        {% for res in reservations %}
            <tr>
                <td>{{ res.user.fullName }}</td>
                <td>{{ res.book.title }}</td>
                <td>{{ res.startDate|date('d/m/Y') }}</td>
                <td>{{ res.endDate|date('d/m/Y') }}</td>
                <td>{{ res.createdAt|date('d/m/Y H:i') }}</td>
                <td>
                    <span class="badge {{ res.status == 'approved' ? 'bg-success' : (res.status == 'pending' ? 'bg-warning text-dark' : (res.status == 'returned' ? 'bg-secondary' : 'bg-danger')) }}">
                        {{ res.statusLabel }}
                    </span>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6" class="text-center text-muted py-4">Aucune réservation.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
