{% extends 'admin/base_admin.html.twig' %}
{% block title %}Réservations — Admin{% endblock %}
{% block body %}
<h2 class="mb-4"><i class="bi bi-calendar-check"></i> Gestion des réservations</h2>
<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr><th>Utilisateur</th><th>Livre</th><th>Du</th><th>Au</th><th>Statut</th><th>Actions</th></tr>
        </thead>
        <tbody>
        {% for res in reservations %}
            <tr>
                <td>{{ res.user.fullName }}</td>
                <td>{{ res.book.title }}</td>
                <td>{{ res.startDate|date('d/m/Y') }}</td>
                <td>{{ res.endDate|date('d/m/Y') }}</td>
                <td>
                    <span class="badge {{ res.status == 'approved' ? 'bg-success' : (res.status == 'pending' ? 'bg-warning text-dark' : (res.status == 'returned' ? 'bg-secondary' : 'bg-danger')) }}">
                        {{ res.statusLabel }}
                    </span>
                </td>
                <td>
                    {% if res.status == 'pending' %}
                        <form method="post" action="{{ path('app_admin_reservation_status', {id: res.id}) }}" class="d-inline">
                            <input type="hidden" name="status" value="approved">
                            <button class="btn btn-sm btn-success">Approuver</button>
                        </form>
                        <form method="post" action="{{ path('app_admin_reservation_status', {id: res.id}) }}" class="d-inline">
                            <input type="hidden" name="status" value="cancelled">
                            <button class="btn btn-sm btn-danger">Annuler</button>
                        </form>
                    {% elseif res.status == 'approved' %}
                        <form method="post" action="{{ path('app_admin_reservation_status', {id: res.id}) }}" class="d-inline">
                            <input type="hidden" name="status" value="returned">
                            <button class="btn btn-sm btn-secondary">Marquer retourné</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
