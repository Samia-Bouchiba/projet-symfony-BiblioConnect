{% extends 'admin/base_admin.html.twig' %}
{% block title %}Utilisateurs — Admin{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Gestion des utilisateurs</h2>
    <span class="badge bg-secondary">{{ users|length }} utilisateur(s)</span>
</div>
<div class="card">
    <table class="table table-hover mb-0">
        <thead class="table-dark">
            <tr><th>Nom</th><th>Email</th><th>Rôle</th><th>Statut</th><th>Inscrit le</th><th>Actions</th></tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr class="{{ not user.active ? 'table-secondary' : '' }}">
                <td>{{ user.fullName }}</td>
                <td>{{ user.email }}</td>
                <td>
                    {% if user == app.user %}
                        <span class="badge rounded-pill bg-danger px-3 py-2">Administrateur</span>
                    {% else %}
                        <form method="post" action="{{ path('app_admin_user_role', {id: user.id}) }}" class="d-inline">
                            <select name="role" class="form-select form-select-sm d-inline-block w-auto" onchange="this.form.submit()">
                                <option value="ROLE_USER" {{ 'ROLE_ADMIN' not in user.roles and 'ROLE_LIBRARIAN' not in user.roles ? 'selected' : '' }}>Usager</option>
                                <option value="ROLE_LIBRARIAN" {{ 'ROLE_LIBRARIAN' in user.roles ? 'selected' : '' }}>Bibliothécaire</option>
                                <option value="ROLE_ADMIN" {{ 'ROLE_ADMIN' in user.roles ? 'selected' : '' }}>Admin</option>
                            </select>
                        </form>
                    {% endif %}
                </td>
                <td>
                    <span class="badge {{ user.active ? 'bg-success' : 'bg-danger' }}">
                        {{ user.active ? 'Actif' : 'Désactivé' }}
                    </span>
                </td>
                <td>{{ user.createdAt|date('d/m/Y') }}</td>
                <td>
                    {% if user == app.user %}
                        <button class="btn btn-sm btn-outline-secondary" disabled title="Vous ne pouvez pas désactiver votre propre compte">
                            <i class="bi bi-lock me-1"></i>Votre compte
                        </button>
                    {% else %}
                        <form method="post" action="{{ path('app_admin_user_toggle', {id: user.id}) }}">
                            <button class="btn btn-sm {{ user.active ? 'btn-outline-danger' : 'btn-outline-success' }}">
                                {{ user.active ? 'Désactiver' : 'Activer' }}
                            </button>
                        </form>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
