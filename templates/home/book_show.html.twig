{% extends 'base.html.twig' %}

{% block title %}{{ book.title }} — BiblioConnect{% endblock %}

{% block body %}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_books') }}">Catalogue</a></li>
        <li class="breadcrumb-item active">{{ book.title }}</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-3 text-center">
        {% if book.coverImage %}
            <img src="/uploads/books/{{ book.coverImage }}" class="img-fluid rounded shadow" alt="{{ book.title }}" style="max-height:350px">
        {% else %}
            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height:300px">
                <i class="bi bi-book text-secondary" style="font-size:5rem"></i>
            </div>
        {% endif %}

        <div class="mt-3">
            <span class="badge {{ book.available ? 'bg-success' : 'bg-danger' }} fs-6">
                {{ book.available ? 'Disponible (' ~ book.stock ~ ' ex.)' : 'Indisponible' }}
            </span>
        </div>

        {% if app.user %}
            {% if book.available %}
                <a href="{{ path('app_book_reserve', {id: book.id}) }}" class="btn btn-primary mt-2 w-100">
                    <i class="bi bi-calendar-check"></i> Réserver
                </a>
            {% endif %}
            <form method="post" action="{{ path('app_book_favorite', {id: book.id}) }}" class="mt-2">
                <input type="hidden" name="_token" value="{{ csrf_token('favorite' ~ book.id) }}">
                <button class="btn btn-outline-warning w-100">
                    {% if book.favoritedBy.contains(app.user) %}
                        <i class="bi bi-heart-fill text-danger"></i> Retirer des favoris
                    {% else %}
                        <i class="bi bi-heart"></i> Ajouter aux favoris
                    {% endif %}
                </button>
            </form>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-outline-primary mt-2 w-100">
                <i class="bi bi-lock"></i> Connectez-vous pour réserver
            </a>
        {% endif %}
    </div>

    <div class="col-md-9">
        <h1 class="h2 fw-bold">{{ book.title }}</h1>

        {% if book.authors is not empty %}
            <p class="text-muted fs-5">
                <i class="bi bi-person"></i>
                {% for author in book.authors %}
                    {{ author.fullName }}{% if not loop.last %}, {% endif %}
                {% endfor %}
            </p>
        {% endif %}

        <div class="d-flex flex-wrap gap-2 mb-3">
            {% for cat in book.categories %}
                <a href="{{ path('app_books', {category: cat.id}) }}" class="badge bg-primary text-decoration-none">{{ cat.name }}</a>
            {% endfor %}
            {% if book.language %}
                <span class="badge bg-secondary">{{ book.language.name }}</span>
            {% endif %}
        </div>

        {% if book.averageRating %}
            <div class="mb-3">
                {% for i in 1..5 %}
                    <i class="bi bi-star{% if i <= book.averageRating %}-fill star-fill{% endif %} fs-5"></i>
                {% endfor %}
                <span class="text-muted ms-1">{{ book.averageRating }}/5</span>
            </div>
        {% endif %}

        {% if book.isbn %}<p><strong>ISBN :</strong> {{ book.isbn }}</p>{% endif %}
        {% if book.publishedAt %}<p><strong>Publication :</strong> {{ book.publishedAt|date('Y') }}</p>{% endif %}

        {% if book.description %}
            <div class="card mt-3 p-3">
                <h5>Description</h5>
                <p class="mb-0">{{ book.description }}</p>
            </div>
        {% endif %}

        {# Avis #}
        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>Avis des lecteurs</h4>
                {% if app.user %}
                    <a href="{{ path('app_book_comment', {id: book.id}) }}" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-chat-left-text"></i> Laisser un avis
                    </a>
                {% endif %}
            </div>

            {# Avis en attente de l'utilisateur connecté #}
            {% if app.user %}
                {% for comment in book.comments %}
                    {% if comment.user == app.user and not comment.approved %}
                        <div class="alert alert-info mt-2">
                            <i class="bi bi-hourglass-split"></i>
                            <strong>Votre avis est en attente de modération :</strong>
                            <div class="mt-1">
                                {% for i in 1..5 %}
                                    <i class="bi bi-star{% if i <= comment.rating %}-fill star-fill{% endif %}"></i>
                                {% endfor %}
                                <span class="ms-2">{{ comment.content }}</span>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {# Commentaires approuvés #}
            {% set has_approved = false %}
            {% for comment in book.comments %}{% if comment.approved %}{% set has_approved = true %}{% endif %}{% endfor %}

            {% for comment in book.comments %}
                {% if comment.approved %}
                    <div class="card mb-2 p-3">
                        <div class="d-flex justify-content-between">
                            <strong>{{ comment.user.fullName }}</strong>
                            <small class="text-muted">{{ comment.createdAt|date('d/m/Y') }}</small>
                        </div>
                        <div class="my-1">
                            {% for i in 1..5 %}
                                <i class="bi bi-star{% if i <= comment.rating %}-fill star-fill{% endif %}"></i>
                            {% endfor %}
                        </div>
                        <p class="mb-0">{{ comment.content }}</p>
                    </div>
                {% endif %}
            {% endfor %}

            {% if not has_approved %}
                <p class="text-muted">Aucun avis approuvé pour le moment. Soyez le premier !</p>
            {% endif %}
        </div>
    </div>
</div>

{% endblock %}
