{% extends 'base.html.twig' %}

{% block title %}Catalogue — BiblioConnect{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-collection"></i> Catalogue</h2>
    <span class="text-muted small">{{ pagination.totalItemCount }} ouvrage(s)</span>
</div>

{# Barre de recherche / filtre #}
<form action="{{ path('app_books') }}" method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" name="q" value="{{ query }}" class="form-control" placeholder="Titre, auteur...">
        </div>
    </div>
    <div class="col-md-4">
        <select name="category" class="form-select">
            <option value="">Toutes les catégories</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}" {{ selected_category == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-2 d-flex gap-2">
        <button class="btn btn-primary flex-grow-1"><i class="bi bi-funnel"></i> Filtrer</button>
        {% if query or selected_category %}
            <a href="{{ path('app_books') }}" class="btn btn-outline-secondary" title="Réinitialiser"><i class="bi bi-x-lg"></i></a>
        {% endif %}
    </div>
</form>

{# Grille livres #}
{% if pagination.totalItemCount == 0 %}
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search" style="font-size:3rem"></i>
        <p class="mt-3 fs-5">Aucun ouvrage trouvé pour « {{ query }} ».</p>
        <a href="{{ path('app_books') }}" class="btn btn-outline-primary mt-2">Voir tout le catalogue</a>
    </div>
{% else %}
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
        {% for book in pagination %}
            <div class="col">
                <div class="card h-100">
                    {% if book.coverImage %}
                        <img src="/uploads/books/{{ book.coverImage }}" class="card-img-top" alt="{{ book.title }}">
                    {% else %}
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center">
                            <i class="bi bi-book text-secondary" style="font-size:3rem"></i>
                        </div>
                    {% endif %}
                    <div class="card-body pb-1">
                        <h6 class="card-title fw-bold mb-1" style="line-height:1.3">{{ book.title }}</h6>
                        <p class="text-muted small mb-1">
                            {% for author in book.authors %}{{ author.fullName }}{% if not loop.last %}, {% endif %}{% endfor %}
                        </p>
                        <div class="mb-1">
                            {% for cat in book.categories|slice(0, 2) %}
                                <span class="badge bg-light text-dark" style="font-size:.7rem">{{ cat.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center py-2">
                        <span class="badge {{ book.available ? 'bg-success' : 'bg-danger' }}">
                            {{ book.available ? 'Dispo' : 'Indispo' }}
                        </span>
                        <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-primary btn-sm">
                            Voir <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if pagination.pageCount > 1 %}
        <nav class="mt-4 d-flex justify-content-center align-items-center gap-3">
            <span class="text-muted small">Page {{ pagination.currentPageNumber }} / {{ pagination.pageCount }}</span>
            <ul class="pagination mb-0">
                {% if pagination.currentPageNumber > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('app_books', {page: 1, q: query, category: selected_category}) }}" title="Première page">
                            <i class="bi bi-chevron-double-left"></i>
                        </a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="{{ path('app_books', {page: pagination.currentPageNumber - 1, q: query, category: selected_category}) }}">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                {% endif %}

                {% set start = max(1, pagination.currentPageNumber - 2) %}
                {% set end   = min(pagination.pageCount, start + 4) %}
                {% set start = max(1, end - 4) %}
                {% for p in start..end %}
                    <li class="page-item {{ p == pagination.currentPageNumber ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_books', {page: p, q: query, category: selected_category}) }}">{{ p }}</a>
                    </li>
                {% endfor %}

                {% if pagination.currentPageNumber < pagination.pageCount %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('app_books', {page: pagination.currentPageNumber + 1, q: query, category: selected_category}) }}">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="{{ path('app_books', {page: pagination.pageCount, q: query, category: selected_category}) }}" title="Dernière page">
                            <i class="bi bi-chevron-double-right"></i>
                        </a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    {% endif %}
{% endif %}

{% endblock %}
